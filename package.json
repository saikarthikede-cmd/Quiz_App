{
  "name": "quiz-app",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "dev:all": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-all.ps1",
    "docker:app:e2e": "powershell -ExecutionPolicy Bypass -File ./scripts/docker-e2e.ps1",
    "docker:app:multitenant": "powershell -ExecutionPolicy Bypass -File ./scripts/docker-multitenant-e2e.ps1",
    "docker:app:up": "powershell -ExecutionPolicy Bypass -File ./scripts/docker-start.ps1",
    "docker:app:smoke": "powershell -ExecutionPolicy Bypass -File ./scripts/docker-smoke.ps1",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "db:migrate": "pnpm --filter @quiz-app/db migrate",
    "db:seed": "pnpm --filter @quiz-app/api-server seed",
    "db:reset-platform": "dotenv -e .env -- tsx scripts/reset-platform-data.ts",
    "dev:api": "pnpm --filter @quiz-app/api-server dev",
    "dev:frontend": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-frontend.ps1",
    "dev:game": "pnpm --filter @quiz-app/game-server dev",
    "dev:worker": "pnpm --filter @quiz-app/worker-server dev",
    "lint": "pnpm -r lint",
    "reset:local": "powershell -ExecutionPolicy Bypass -File ./scripts/reset-local.ps1",
    "test:create-session": "dotenv -e .env -- tsx scripts/test-create-session.ts",
    "test:socket-client": "dotenv -e .env -- tsx scripts/socket-test-client.ts"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "dotenv-cli": "^10.0.0",
    "rimraf": "^6.0.1",
    "socket.io-client": "^4.8.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
